# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# PostgreSQL connection string (must have PostGIS extension enabled)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kaun

# "development" | "production"
APP_ENV=development

# Comma-separated allowed CORS origins. Use * for local dev only.
CORS_ORIGINS=*
